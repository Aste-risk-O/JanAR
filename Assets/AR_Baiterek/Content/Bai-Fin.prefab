--- !u!114 &8214118800230173937
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 612278084792539820}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f117daeb9ef75484e9a59418dd1368b2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  uiText: {fileID: 3924466795455507930}
  textPanel: {fileID: 471538755220869597}
  musicSource: {fileID: 7629630470588985317}
  vinesAnim: {fileID: 905720352413478416}
  birdAnim: {fileID: 858128804348318382}
  eggAnim: {fileID: 1469644123239670771}
  textsRU:
  - "\u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435 \u043C\u0438\u0440\u0430 \u0440\u043E\u0441\u043B\u043E
    \u0414\u0440\u0435\u0432\u043E \u0436\u0438\u0437\u043D\u0438 \u2014 \u0411\u0430\u0439\u0442\u0435\u0440\u0435\u043A.
    \u0415\u0433\u043E \u043A\u043E\u0440\u043D\u0438 \u0434\u0435\u0440\u0436\u0430\u043B\u0438
    \u0437\u0435\u043C\u043B\u044E, \u0430 \u043A\u0440\u043E\u043D\u0430 \u043F\u043E\u0434\u043F\u0438\u0440\u0430\u043B\u0430
    \u043D\u0435\u0431\u043E."
  - "\u041A\u0430\u0436\u0434\u044B\u0439 \u0433\u043E\u0434 \u0441\u044E\u0434\u0430
    \u043F\u0440\u0438\u043B\u0435\u0442\u0430\u043B\u0430 \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0430\u044F
    \u043F\u0442\u0438\u0446\u0430 \u0421\u0430\u043C\u0440\u0443\u043A. \u0412\u0435\u0442\u0432\u0438
    \u0434\u0435\u0440\u0435\u0432\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438\u0441\u044C
    \u0434\u043B\u044F \u043D\u0435\u0451 \u043F\u0440\u0438\u0431\u0435\u0436\u0438\u0449\u0435\u043C."
  - "\u041E\u043D\u0430 \u043E\u0442\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u043B\u0430
    \u0417\u043E\u043B\u043E\u0442\u043E\u0435 \u044F\u0439\u0446\u043E \u2014 \u0421\u043E\u043B\u043D\u0446\u0435.
    \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0411\u0430\u0439\u0442\u0435\u0440\u0435\u043A
    \u2014 \u044D\u0442\u043E \u0441\u0438\u043C\u0432\u043E\u043B \u0436\u0438\u0437\u043D\u0438
    \u0438 \u043D\u0430\u0448\u0435\u0433\u043E \u0441\u0432\u0435\u0442\u043B\u043E\u0433\u043E
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E."
  textsKZ:
  - "\u0410\u04A3\u044B\u0437 \u0431\u043E\u0439\u044B\u043D\u0448\u0430, \u04D9\u043B\u0435\u043C\u043D\u0456\u04A3
    \u043E\u0440\u0442\u0430\u0441\u044B\u043D\u0434\u0430 \u0411\u04D9\u0439\u0442\u0435\u0440\u0435\u043A
    \u2014 \u04E8\u043C\u0456\u0440 \u0430\u0493\u0430\u0448\u044B \u04E9\u0441\u043A\u0435\u043D.
    \u041E\u043D\u044B\u04A3 \u0442\u0430\u043C\u044B\u0440\u044B \u0436\u0435\u0440\u0434\u0456
    \u04B1\u0441\u0442\u0430\u043F, \u0431\u04B1\u0442\u0430\u0493\u044B \u043A\u04E9\u043A\u043A\u0435
    \u0436\u0435\u0442\u043A\u0435\u043D."
  - "\u0416\u044B\u043B \u0441\u0430\u0439\u044B\u043D \u0431\u04B1\u043B \u0430\u0493\u0430\u0448\u049B\u0430
    \u043A\u0438\u0435\u043B\u0456 \u0421\u0430\u043C\u04B1\u0440\u044B\u049B \u049B\u04B1\u0441\u044B
    \u04B1\u0448\u044B\u043F \u043A\u0435\u043B\u0435\u0442\u0456\u043D. \u0410\u0493\u0430\u0448\u0442\u044B\u04A3
    \u0431\u04B1\u0442\u0430\u049B\u0442\u0430\u0440\u044B \u043E\u0493\u0430\u043D
    \u043F\u0430\u043D\u0430 \u0431\u043E\u043B\u0430\u0442\u044B\u043D."
  - "\u041E\u043B \u0410\u043B\u0442\u044B\u043D \u0436\u04B1\u043C\u044B\u0440\u0442\u049B\u0430
    \u2014 \u041A\u04AF\u043D\u0434\u0456 \u0441\u0430\u043B\u0430\u0442\u044B\u043D.
    \u0411\u04AF\u0433\u0456\u043D\u0434\u0435 \u0411\u04D9\u0439\u0442\u0435\u0440\u0435\u043A
    \u2014 \u04E9\u043C\u0456\u0440\u0434\u0456\u04A3 \u0436\u04D9\u043D\u0435 \u0436\u0430\u0440\u049B\u044B\u043D
    \u0431\u043E\u043B\u0430\u0448\u0430\u0493\u044B\u043C\u044B\u0437\u0434\u044B\u04A3
    \u0441\u0438\u043C\u0432\u043E\u043B\u044B.\u043C\u0456\u0440 \u0430\u0493\u0430\u0448\u044B
    \u04E9\u0441\u043A\u0435\u043D. \u041E\u043D\u044B\u04A3 \u0442\u0430\u043C\u044B\u0440\u044B
    \u0436\u0435\u0440\u0434\u0456 \u04B1\u0441\u0442\u0430\u043F, \u0431\u04B1\u0442\u0430\u0493\u044B
    \u043A\u04E9\u043A\u043A\u0435 \u0436\u0435\u0442\u043A\u0435\u043D."
  textsEN:
  - "According to legend, the Tree of Life \u2014 Baiterek \u2014 grew in the center
    of the world. Its roots held the earth, and its crown touched the sky."
  - Every year, the sacred bird Samruk flew here. The branches of the tree became
    a safe haven for her.
  - "She laid the Golden Egg \u2014 the Sun. Today, Baiterek is a symbol of life
    and our bright future."
